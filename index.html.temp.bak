<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Racks Paraguay | Soluciones de Almacenamiento Metálico</title>
<meta name="description" content="Fabricantes e instaladores de racks metálicos en Paraguay. Más de una década de experiencia. Km 26 Ruta 2, Itauguá.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;400;600;700;900&family=Barlow:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ===========================
   RESET & CSS VARIABLES
=========================== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --red:       #E8161C;
  --red-dark:  #A80F13;
  --steel:     #0D1B2A;
  --steel-mid: #1A2E45;
  --steel-lt:  #243B55;
  --silver:    #B0BEC5;
  --white:     #F5F7F9;
  --off:       #EDF0F3;
  --accent:    #00C9A7;
  --gold:      #F5C842;
  --gap:       clamp(1rem, 4vw, 3rem);
  --r:         6px;
  --nav-h:     72px;
  --trans:     all .35s cubic-bezier(.4,0,.2,1);
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Barlow', sans-serif;
  background: var(--white);
  color: var(--steel);
  overflow-x: hidden;
  font-size: 16px;
  line-height: 1.6;
}

img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
ul { list-style: none; }

.container {
  width: min(1300px, 92vw);
  margin-inline: auto;
}

.tag {
  display: inline-block;
  font-family: 'DM Mono', monospace;
  font-size: .7rem;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: .75rem;
}

h1,h2,h3,h4,h5 {
  font-family: 'Barlow Condensed', sans-serif;
  line-height: 1.05;
  font-weight: 700;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .8rem 2rem;
  border-radius: var(--r);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: .05em;
  text-transform: uppercase;
  cursor: pointer;
  transition: var(--trans);
  border: 2px solid transparent;
}

.btn-red {
  background: var(--red);
  color: #fff;
  border-color: var(--red);
}
.btn-red:hover {
  background: var(--red-dark);
  border-color: var(--red-dark);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(232,22,28,.35);
}

.btn-outline {
  background: transparent;
  color: #fff;
  border-color: rgba(255,255,255,.5);
}
.btn-outline:hover {
  background: #fff;
  color: var(--steel);
  border-color: #fff;
}

.btn-green {
  background: var(--accent);
  color: var(--steel);
  border-color: var(--accent);
}
.btn-green:hover {
  background: #00a88d;
  border-color: #00a88d;
  transform: translateY(-2px);
}

/* WhatsApp float */
.wa-float {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  z-index: 9999;
  width: 58px;
  height: 58px;
  border-radius: 50%;
  background: #25D366;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 20px rgba(37,211,102,.5);
  animation: pulse-wa 2s infinite;
  transition: var(--trans);
}
.wa-float:hover { transform: scale(1.1); }
.wa-float svg { width: 30px; height: 30px; fill: #fff; }

@keyframes pulse-wa {
  0%,100% { box-shadow: 0 4px 20px rgba(37,211,102,.5); }
  50% { box-shadow: 0 4px 36px rgba(37,211,102,.8); }
}

/* ===========================
   NAVBAR
=========================== */
#navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  height: var(--nav-h);
  display: flex;
  align-items: center;
  transition: background .4s, box-shadow .4s;
}
#navbar.scrolled {
  background: rgba(13,27,42,.97);
  backdrop-filter: blur(12px);
  box-shadow: 0 2px 30px rgba(0,0,0,.4);
}

.nav-inner {
  width: min(1400px, 94vw);
  margin-inline: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
}

.logo-wrap img {
  height: 52px;
  width: auto;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,.4));
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 2rem;
}

.nav-links a {
  color: rgba(255,255,255,.85);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  position: relative;
  transition: color .3s;
}
.nav-links a::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0;
  width: 0; height: 2px;
  background: var(--red);
  transition: width .3s;
}
.nav-links a:hover { color: #fff; }
.nav-links a:hover::after { width: 100%; }

.nav-cta {
  padding: .6rem 1.4rem;
  background: var(--red);
  color: #fff !important;
  border-radius: var(--r);
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: .9rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  transition: var(--trans);
}
.nav-cta:hover {
  background: var(--red-dark);
  transform: translateY(-1px);
}
.nav-cta::after { display: none !important; }

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  cursor: pointer;
  padding: 4px;
  background: none;
  border: none;
}
.hamburger span {
  display: block;
  width: 26px;
  height: 2px;
  background: #fff;
  transition: var(--trans);
  transform-origin: center;
}
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

.mobile-menu {
  display: none;
  position: fixed;
  top: var(--nav-h); left: 0; right: 0;
  background: rgba(13,27,42,.98);
  backdrop-filter: blur(12px);
  padding: 2rem;
  flex-direction: column;
  gap: 1.5rem;
  z-index: 999;
  border-top: 1px solid rgba(255,255,255,.08);
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  color: rgba(255,255,255,.85);
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  transition: color .3s;
}
.mobile-menu a:hover { color: var(--red); }

/* ===========================
   HERO
=========================== */
#hero {
  position: relative;
  height: 100svh;
  min-height: 600px;
  display: flex;
  align-items: center;
  overflow: hidden;
}

.hero-video {
  position: absolute;
  inset: 0;
  z-index: 0;
}
.hero-video video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(13,27,42,.92) 0%,
    rgba(13,27,42,.7) 50%,
    rgba(13,27,42,.45) 100%
  );
  z-index: 1;
}

/* Diagonal red slash */
.hero-slash {
  position: absolute;
  top: 0; right: 0;
  width: 45%;
  height: 100%;
  background: linear-gradient(135deg, transparent 40%, rgba(232,22,28,.15) 100%);
  z-index: 1;
  clip-path: polygon(30% 0, 100% 0, 100% 100%, 0% 100%);
}

.hero-content {
  position: relative;
  z-index: 2;
  width: min(1300px, 92vw);
  margin-inline: auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--gap);
  align-items: center;
}

.hero-left { padding-top: 2rem; }

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin-bottom: 1.5rem;
  animation: fadeUp .8s .2s both;
}
.hero-eyebrow-line {
  width: 40px;
  height: 2px;
  background: var(--red);
}
.hero-eyebrow span {
  font-family: 'DM Mono', monospace;
  font-size: .75rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--silver);
}

.hero-title {
  font-size: clamp(3rem, 7vw, 6.5rem);
  color: #fff;
  text-transform: uppercase;
  line-height: .95;
  animation: fadeUp .8s .3s both;
}
.hero-title em {
  font-style: normal;
  color: var(--red);
  display: block;
}
.hero-title .outline {
  -webkit-text-stroke: 2px rgba(255,255,255,.3);
  color: transparent;
}

.hero-sub {
  margin-top: 1.5rem;
  font-size: 1.1rem;
  color: rgba(255,255,255,.7);
  max-width: 480px;
  line-height: 1.65;
  animation: fadeUp .8s .4s both;
}

.hero-btns {
  display: flex;
  gap: 1rem;
  margin-top: 2.5rem;
  flex-wrap: wrap;
  animation: fadeUp .8s .5s both;
}

.hero-stats {
  display: flex;
  gap: 2.5rem;
  margin-top: 3rem;
  animation: fadeUp .8s .6s both;
}
.hero-stat-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 2.8rem;
  font-weight: 900;
  color: var(--red);
  line-height: 1;
}
.hero-stat-label {
  font-size: .8rem;
  color: rgba(255,255,255,.55);
  text-transform: uppercase;
  letter-spacing: .1em;
  margin-top: .2rem;
}

.hero-right {
  display: flex;
  justify-content: center;
  animation: fadeLeft .9s .4s both;
}

.hero-card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: .75rem;
  max-width: 420px;
}

.hero-card {
  background: rgba(255,255,255,.06);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 12px;
  padding: 1.25rem;
  transition: var(--trans);
}
.hero-card:hover {
  background: rgba(255,255,255,.1);
  border-color: var(--red);
  transform: translateY(-4px);
}
.hero-card-icon {
  font-size: 1.8rem;
  margin-bottom: .5rem;
}
.hero-card-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: .05em;
}
.hero-card-desc {
  font-size: .78rem;
  color: rgba(255,255,255,.55);
  margin-top: .25rem;
  line-height: 1.4;
}
.hero-card.span-2 { grid-column: span 2; }

/* scroll indicator */
.scroll-hint {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .5rem;
  animation: bounce 2s infinite;
}
.scroll-hint span {
  font-family: 'DM Mono', monospace;
  font-size: .6rem;
  letter-spacing: .2em;
  color: rgba(255,255,255,.4);
  text-transform: uppercase;
}
.scroll-arrow {
  width: 24px;
  height: 24px;
  border-right: 2px solid rgba(255,255,255,.3);
  border-bottom: 2px solid rgba(255,255,255,.3);
  transform: rotate(45deg);
}

@keyframes bounce {
  0%,100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}

/* ===========================
   STRIP — PILARES
=========================== */
#pilares {
  background: var(--steel);
  padding: 2.5rem 0;
  position: relative;
  overflow: hidden;
}
#pilares::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, transparent, var(--red), transparent);
}

.pilares-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 1rem;
}

.pilar-item {
  display: flex;
  align-items: center;
  gap: .75rem;
  padding: .75rem;
  border-radius: var(--r);
  transition: background .3s;
}
.pilar-item:hover { background: rgba(255,255,255,.05); }

.pilar-icon {
  width: 40px;
  height: 40px;
  border-radius: 8px;
  background: linear-gradient(135deg, var(--red), var(--red-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  flex-shrink: 0;
}

.pilar-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .95rem;
  font-weight: 700;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: .05em;
}
.pilar-sub {
  font-size: .72rem;
  color: var(--silver);
  margin-top: .1rem;
  line-height: 1.3;
}

/* ===========================
   SECTION HEADINGS utility
=========================== */
.section-head {
  text-align: center;
  margin-bottom: 3.5rem;
}
.section-head h2 {
  font-size: clamp(2.4rem, 5vw, 4rem);
  text-transform: uppercase;
}
.section-head h2 span { color: var(--red); }
.section-head p {
  max-width: 560px;
  margin: 1rem auto 0;
  color: #556;
  font-size: 1.05rem;
}

/* ===========================
   QUIÉNES SOMOS (Hotmart-style)
=========================== */
#quienes {
  padding: 6rem 0;
  background: var(--white);
}

.quienes-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 5rem;
  align-items: center;
}

.quienes-img-wrap {
  position: relative;
}
.quienes-img-wrap img {
  border-radius: 16px;
  width: 100%;
  object-fit: cover;
  box-shadow: 0 30px 80px rgba(0,0,0,.18);
}

.quienes-badge {
  position: absolute;
  bottom: -20px;
  right: -20px;
  background: var(--red);
  color: #fff;
  border-radius: 12px;
  padding: 1.25rem 1.5rem;
  text-align: center;
  box-shadow: 0 8px 30px rgba(232,22,28,.4);
}
.quienes-badge-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 3rem;
  font-weight: 900;
  line-height: 1;
}
.quienes-badge-label {
  font-size: .78rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  opacity: .85;
}

.quienes-content { }
.quienes-content h2 {
  font-size: clamp(2rem, 3.5vw, 3.2rem);
  text-transform: uppercase;
  line-height: 1.05;
}
.quienes-content h2 span { color: var(--red); }
.quienes-content p {
  color: #445;
  font-size: 1.05rem;
  margin: 1.5rem 0;
  line-height: 1.7;
}

.check-list {
  display: flex;
  flex-direction: column;
  gap: .75rem;
  margin: 1.75rem 0;
}
.check-item {
  display: flex;
  align-items: flex-start;
  gap: .75rem;
  font-size: 1rem;
  color: #334;
}
.check-item::before {
  content: '✓';
  width: 24px;
  height: 24px;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .75rem;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 2px;
}

/* ===========================
   PARA QUIÉN ES / NO ES  (Hotmart)
=========================== */
#para-quien {
  padding: 6rem 0;
  background: var(--steel);
}

#para-quien .section-head h2 { color: #fff; }
#para-quien .section-head p { color: var(--silver); }

.pq-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
}

.pq-card {
  border-radius: 16px;
  padding: 2.5rem;
}
.pq-card.yes {
  background: linear-gradient(135deg, rgba(0,201,167,.12), rgba(0,201,167,.04));
  border: 1px solid rgba(0,201,167,.25);
}
.pq-card.no {
  background: linear-gradient(135deg, rgba(232,22,28,.12), rgba(232,22,28,.04));
  border: 1px solid rgba(232,22,28,.2);
}

.pq-header {
  display: flex;
  align-items: center;
  gap: .75rem;
  margin-bottom: 1.75rem;
}
.pq-emoji { font-size: 2rem; }
.pq-header h3 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.6rem;
  text-transform: uppercase;
  color: #fff;
}

.pq-items {
  display: flex;
  flex-direction: column;
  gap: .9rem;
}
.pq-item {
  display: flex;
  align-items: flex-start;
  gap: .75rem;
  color: rgba(255,255,255,.8);
  font-size: .97rem;
  line-height: 1.5;
}
.pq-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: .45rem;
}
.yes .pq-dot { background: var(--accent); }
.no .pq-dot { background: var(--red); }

/* ===========================
   CATÁLOGO
=========================== */
#catalogo {
  padding: 6rem 0;
  background: var(--off);
}

.cat-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
}

.cat-card {
  background: #fff;
  border-radius: 14px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,.07);
  transition: var(--trans);
  cursor: pointer;
  border: 1px solid rgba(0,0,0,.06);
}
.cat-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 16px 48px rgba(0,0,0,.14);
  border-color: var(--red);
}

.cat-card-img {
  aspect-ratio: 1;
  overflow: hidden;
  position: relative;
  background: var(--steel);
}
.cat-card-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .5s;
}
.cat-card:hover .cat-card-img img { transform: scale(1.06); }

.cat-card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(0deg, rgba(13,27,42,.8) 0%, transparent 60%);
  opacity: 0;
  transition: opacity .3s;
  display: flex;
  align-items: flex-end;
  padding: 1.25rem;
}
.cat-card:hover .cat-card-overlay { opacity: 1; }
.cat-overlay-btn {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .9rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: .1em;
  text-transform: uppercase;
  background: var(--red);
  padding: .5rem 1.25rem;
  border-radius: 6px;
  width: 100%;
  text-align: center;
}

.cat-card-body {
  padding: 1.25rem;
}
.cat-card-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.3rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--steel);
  margin-bottom: .4rem;
}
.cat-card-desc {
  font-size: .85rem;
  color: #667;
  line-height: 1.5;
}

/* ===========================
   SOLUCIONES por industria
=========================== */
#soluciones {
  padding: 6rem 0;
  background: var(--white);
}

.sol-tabs {
  display: flex;
  gap: .5rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 3rem;
}
.sol-tab {
  padding: .55rem 1.4rem;
  border-radius: 100px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .9rem;
  font-weight: 600;
  letter-spacing: .05em;
  text-transform: uppercase;
  background: var(--off);
  color: #667;
  border: 1px solid transparent;
  cursor: pointer;
  transition: var(--trans);
}
.sol-tab.active, .sol-tab:hover {
  background: var(--red);
  color: #fff;
  border-color: var(--red);
}

.sol-content {
  display: none;
  animation: fadeUp .4s both;
}
.sol-content.active { display: block; }

.sol-content-inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}
.sol-content-inner img {
  border-radius: 14px;
  width: 100%;
  object-fit: cover;
  box-shadow: 0 20px 60px rgba(0,0,0,.12);
}

.sol-text h3 {
  font-size: clamp(1.8rem, 3vw, 2.5rem);
  text-transform: uppercase;
  margin-bottom: 1rem;
}
.sol-text h3 span { color: var(--red); }
.sol-text p {
  color: #556;
  font-size: 1rem;
  line-height: 1.7;
  margin-bottom: 1.5rem;
}

/* ===========================
   GALERÍA
=========================== */
#galeria {
  padding: 6rem 0;
  background: var(--steel);
}
#galeria .section-head h2 { color: #fff; }
#galeria .section-head p { color: var(--silver); }

.gallery-masonry {
  columns: 3;
  column-gap: 1rem;
}
.gallery-item {
  break-inside: avoid;
  margin-bottom: 1rem;
  border-radius: 10px;
  overflow: hidden;
  position: relative;
  cursor: zoom-in;
}
.gallery-item img {
  width: 100%;
  display: block;
  transition: transform .5s;
}
.gallery-item:hover img { transform: scale(1.04); }

/* ===========================
   PROCESO (timeline)
=========================== */
#proceso {
  padding: 6rem 0;
  background: var(--off);
}

.proceso-steps {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  position: relative;
}
.proceso-steps::before {
  content: '';
  position: absolute;
  top: 44px;
  left: 12%;
  right: 12%;
  height: 2px;
  background: linear-gradient(90deg, var(--red), var(--accent));
}

.proceso-step {
  text-align: center;
  position: relative;
  padding-top: 1rem;
}
.step-num {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--red);
  color: #fff;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.4rem;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.25rem;
  position: relative;
  z-index: 1;
  box-shadow: 0 4px 20px rgba(232,22,28,.4);
}

.step-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.2rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--steel);
  margin-bottom: .4rem;
}
.step-desc { font-size: .85rem; color: #667; line-height: 1.5; }

/* ===========================
   TESTIMONIOS
=========================== */
#testimonios {
  padding: 6rem 0;
  background: var(--white);
}

.testi-slider {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.5rem;
}

.testi-card {
  background: #fff;
  border: 1px solid rgba(0,0,0,.07);
  border-radius: 16px;
  padding: 2rem;
  box-shadow: 0 4px 20px rgba(0,0,0,.06);
  transition: var(--trans);
  position: relative;
}
.testi-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 40px rgba(0,0,0,.12);
  border-color: var(--accent);
}

.testi-stars {
  color: var(--gold);
  font-size: 1rem;
  letter-spacing: .1em;
  margin-bottom: 1rem;
}
.testi-text {
  font-size: 1rem;
  color: #445;
  line-height: 1.65;
  font-style: italic;
  margin-bottom: 1.5rem;
}
.testi-quote {
  position: absolute;
  top: 1.5rem; right: 1.75rem;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 5rem;
  font-weight: 900;
  color: var(--red);
  opacity: .1;
  line-height: 1;
}

.testi-author {
  display: flex;
  align-items: center;
  gap: .75rem;
}
.testi-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--red), var(--red-dark));
  color: #fff;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.2rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}
.testi-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.05rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--steel);
}
.testi-role { font-size: .78rem; color: #889; }

/* ===========================
   PREGUNTAS FRECUENTES
=========================== */
#faq {
  padding: 6rem 0;
  background: var(--off);
}

.faq-list {
  max-width: 800px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: .75rem;
}

.faq-item {
  background: #fff;
  border-radius: 10px;
  border: 1px solid rgba(0,0,0,.07);
  overflow: hidden;
  transition: box-shadow .3s;
}
.faq-item:hover { box-shadow: 0 4px 20px rgba(0,0,0,.08); }

.faq-q {
  width: 100%;
  text-align: left;
  background: none;
  border: none;
  padding: 1.25rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  cursor: pointer;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.15rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--steel);
  letter-spacing: .03em;
}
.faq-q svg {
  width: 20px; height: 20px;
  flex-shrink: 0;
  transition: transform .3s;
  stroke: var(--red);
}
.faq-item.open .faq-q svg { transform: rotate(45deg); }

.faq-a {
  display: none;
  padding: 0 1.5rem 1.25rem;
  color: #556;
  font-size: .97rem;
  line-height: 1.7;
}
.faq-item.open .faq-a { display: block; }

/* ===========================
   FORMULARIO COTIZACIÓN
=========================== */
#cotizacion {
  padding: 6rem 0;
  background: var(--steel);
  position: relative;
  overflow: hidden;
}
#cotizacion::before {
  content: '';
  position: absolute;
  top: -150px; right: -150px;
  width: 500px; height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(232,22,28,.15) 0%, transparent 70%);
  pointer-events: none;
}

#cotizacion .section-head h2 { color: #fff; }
#cotizacion .section-head p { color: var(--silver); }

.form-wrapper {
  max-width: 820px;
  margin: 0 auto;
  background: rgba(255,255,255,.05);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 20px;
  padding: 3rem;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}
.form-grid .span-2 { grid-column: span 2; }

.field-group {
  display: flex;
  flex-direction: column;
  gap: .4rem;
}
.field-group label {
  font-family: 'DM Mono', monospace;
  font-size: .7rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--silver);
}
.field-group input,
.field-group select,
.field-group textarea {
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: var(--r);
  padding: .85rem 1rem;
  color: #fff;
  font-family: 'Barlow', sans-serif;
  font-size: .97rem;
  transition: border-color .3s, background .3s;
  width: 100%;
}
.field-group input:focus,
.field-group select:focus,
.field-group textarea:focus {
  outline: none;
  border-color: var(--accent);
  background: rgba(255,255,255,.1);
}
.field-group select option { background: var(--steel); }
.field-group textarea { resize: vertical; min-height: 100px; }

.rack-selector {
  grid-column: span 2;
}
.rack-selector-label {
  font-family: 'DM Mono', monospace;
  font-size: .7rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--silver);
  margin-bottom: .75rem;
  display: block;
}
.rack-options {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
  gap: .6rem;
}
.rack-option {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: .4rem;
  padding: .9rem .6rem;
  border-radius: 10px;
  border: 1px solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.05);
  cursor: pointer;
  transition: var(--trans);
  text-align: center;
}
.rack-option:hover {
  border-color: var(--accent);
  background: rgba(0,201,167,.1);
}
.rack-option.selected {
  border-color: var(--accent);
  background: rgba(0,201,167,.15);
  box-shadow: 0 0 0 2px rgba(0,201,167,.3);
}
.rack-option-icon { font-size: 1.6rem; }
.rack-option-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .85rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #fff;
  letter-spacing: .04em;
  line-height: 1.2;
}

.form-submit {
  margin-top: 2rem;
  text-align: center;
}
.form-submit .btn {
  width: 100%;
  justify-content: center;
  font-size: 1.1rem;
  padding: 1rem 2rem;
}

.form-note {
  text-align: center;
  margin-top: 1rem;
  font-size: .8rem;
  color: rgba(255,255,255,.35);
}

.form-success {
  display: none;
  text-align: center;
  padding: 2rem;
}
.form-success h3 {
  font-size: 2rem;
  color: var(--accent);
  margin-bottom: .5rem;
}
.form-success p { color: rgba(255,255,255,.7); }

/* ===========================
   CONTACTO
=========================== */
#contacto {
  padding: 6rem 0;
  background: var(--white);
}

.contact-grid {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 4rem;
  align-items: start;
}

.contact-info h2 {
  font-size: clamp(2rem, 4vw, 3rem);
  text-transform: uppercase;
  margin-bottom: 1rem;
}
.contact-info h2 span { color: var(--red); }
.contact-info p {
  color: #556;
  margin-bottom: 2rem;
  line-height: 1.7;
}

.contact-items {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}
.contact-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.25rem;
  background: var(--off);
  border-radius: 12px;
  border: 1px solid rgba(0,0,0,.06);
  transition: var(--trans);
}
.contact-item:hover {
  border-color: var(--red);
  box-shadow: 0 4px 20px rgba(232,22,28,.08);
}
.ci-icon {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  background: var(--red);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  flex-shrink: 0;
}
.ci-label {
  font-family: 'DM Mono', monospace;
  font-size: .65rem;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: #889;
  margin-bottom: .2rem;
}
.ci-value {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--steel);
}

.horarios-card {
  background: var(--off);
  border-radius: 12px;
  padding: 1.5rem;
  border: 1px solid rgba(0,0,0,.06);
}
.horarios-card h4 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 1.2rem;
  text-transform: uppercase;
  color: var(--steel);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: .5rem;
}
.horario-row {
  display: flex;
  justify-content: space-between;
  padding: .5rem 0;
  border-bottom: 1px solid rgba(0,0,0,.06);
  font-size: .9rem;
  color: #445;
}
.horario-row:last-child { border-bottom: none; }
.horario-day { font-weight: 500; }
.horario-time { color: var(--red); font-weight: 600; }
.horario-cita-btn {
  margin-top: 1rem;
  display: block;
  text-align: center;
  padding: .7rem;
  background: #25D366;
  color: #fff;
  border-radius: 8px;
  font-family: 'Barlow Condensed', sans-serif;
  font-weight: 700;
  font-size: 1rem;
  letter-spacing: .05em;
  text-transform: uppercase;
  transition: var(--trans);
}
.horario-cita-btn:hover {
  background: #1da855;
  transform: translateY(-1px);
}

/* ===========================
   BLOG PREVIEW
=========================== */
#blog {
  padding: 6rem 0;
  background: var(--steel);
}
#blog .section-head h2 { color: #fff; }
#blog .section-head p { color: var(--silver); }

.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}

.blog-card {
  background: rgba(255,255,255,.06);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 14px;
  overflow: hidden;
  transition: var(--trans);
}
.blog-card:hover {
  transform: translateY(-4px);
  border-color: var(--red);
  box-shadow: 0 16px 40px rgba(0,0,0,.3);
}
.blog-card-img {
  aspect-ratio: 16/9;
  overflow: hidden;
  background: var(--steel-mid);
}
.blog-card-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s; }
.blog-card:hover .blog-card-img img { transform: scale(1.05); }

.blog-card-body { padding: 1.5rem; }
.blog-tag {
  display: inline-block;
  background: rgba(232,22,28,.2);
  color: #ff7a7e;
  font-family: 'DM Mono', monospace;
  font-size: .65rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: .2rem .6rem;
  border-radius: 4px;
  margin-bottom: .75rem;
}
.blog-card h4 {
  font-size: 1.2rem;
  text-transform: uppercase;
  color: #fff;
  margin-bottom: .5rem;
  line-height: 1.2;
}
.blog-card p {
  font-size: .85rem;
  color: rgba(255,255,255,.5);
  line-height: 1.55;
}

/* ===========================
   FOOTER
=========================== */
footer {
  background: #060e18;
  padding: 4rem 0 2rem;
  border-top: 3px solid var(--red);
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: 3rem;
  margin-bottom: 3rem;
}

.footer-brand img {
  height: 48px;
  margin-bottom: 1rem;
  filter: brightness(1.1);
}
.footer-brand p {
  color: rgba(255,255,255,.45);
  font-size: .9rem;
  line-height: 1.6;
  max-width: 240px;
}

.footer-col h5 {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: .85rem;
  font-weight: 700;
  letter-spacing: .15em;
  text-transform: uppercase;
  color: var(--silver);
  margin-bottom: 1.25rem;
}

.footer-links {
  display: flex;
  flex-direction: column;
  gap: .6rem;
}
.footer-links a {
  color: rgba(255,255,255,.45);
  font-size: .9rem;
  transition: color .3s;
}
.footer-links a:hover { color: var(--red); }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,.07);
  padding-top: 2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}
.footer-copy {
  color: rgba(255,255,255,.25);
  font-size: .82rem;
}
.footer-copy strong { color: rgba(255,255,255,.45); }

/* ===========================
   ANIMATIONS
=========================== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(30px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeLeft {
  from { opacity: 0; transform: translateX(40px); }
  to { opacity: 1; transform: translateX(0); }
}

.reveal {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity .6s, transform .6s;
}
.reveal.visible {
  opacity: 1;
  transform: translateY(0);
}
.reveal-left {
  opacity: 0;
  transform: translateX(-30px);
  transition: opacity .6s, transform .6s;
}
.reveal-left.visible {
  opacity: 1;
  transform: translateX(0);
}
.reveal-right {
  opacity: 0;
  transform: translateX(30px);
  transition: opacity .6s, transform .6s;
}
.reveal-right.visible {
  opacity: 1;
  transform: translateX(0);
}

/* delay helpers */
.d1 { transition-delay: .1s; }
.d2 { transition-delay: .2s; }
.d3 { transition-delay: .3s; }
.d4 { transition-delay: .4s; }
.d5 { transition-delay: .5s; }

/* ===========================
   RESPONSIVE
=========================== */
@media (max-width: 1024px) {
  .pilares-grid { grid-template-columns: repeat(3, 1fr); }
  .quienes-grid { grid-template-columns: 1fr; gap: 3rem; }
  .quienes-img-wrap { max-width: 500px; margin: 0 auto; }
  .proceso-steps { grid-template-columns: repeat(2, 1fr); }
  .proceso-steps::before { display: none; }
  .contact-grid { grid-template-columns: 1fr; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .hero-content { grid-template-columns: 1fr; }
  .hero-right { display: none; }
  .hero-title { font-size: clamp(2.5rem, 8vw, 4.5rem); }
  .gallery-masonry { columns: 2; }
  .pq-grid { grid-template-columns: 1fr; }
  .sol-content-inner { grid-template-columns: 1fr; }
  .blog-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
  .nav-links { display: none; }
  .hamburger { display: flex; }
  .pilares-grid { grid-template-columns: repeat(2, 1fr); }
  .cat-grid { grid-template-columns: repeat(2, 1fr); }
  .form-grid { grid-template-columns: 1fr; }
  .form-grid .span-2 { grid-column: 1; }
  .rack-selector { grid-column: 1; }
  .form-wrapper { padding: 1.75rem; }
  .footer-grid { grid-template-columns: 1fr; gap: 2rem; }
  .hero-stats { gap: 1.5rem; }
  .blog-grid { grid-template-columns: 1fr; }
  .proceso-steps { grid-template-columns: 1fr; }
  .gallery-masonry { columns: 1; }
  .testi-slider { grid-template-columns: 1fr; }
}

@media (max-width: 480px) {
  .pilares-grid { grid-template-columns: 1fr; }
  .cat-grid { grid-template-columns: 1fr; }
  .hero-btns { flex-direction: column; }
  .hero-btns .btn { width: 100%; justify-content: center; }
}
</style>
</head>
<body>

<!-- WhatsApp Float -->

  </svg>
</a>

<!-- ===== NAVBAR ===== -->
<nav id="navbar">
  <div class="nav-inner">
    <a href="#" class="logo-wrap">
      <img src="https://racksparaguay.com.py/wp-content/uploads/2023/10/racksparaguaylogo-1-1.png" alt="Racks Paraguay">
    </a>
    <div class="nav-links">
      <a href="#quienes">Nosotros</a>
      <a href="#catalogo">Catálogo</a>
      <a href="#soluciones">Soluciones</a>
      <a href="#galeria">Galería</a>
      <a href="#faq">FAQ</a>
      <a href="#contacto">Contacto</a>
      <a href="#cotizacion" class="nav-cta">Cotizar ahora</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Menú">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu">
  <a href="#quienes" class="mobile-link">Nosotros</a>
  <a href="#catalogo" class="mobile-link">Catálogo</a>
  <a href="#soluciones" class="mobile-link">Soluciones</a>
  <a href="#galeria" class="mobile-link">Galería</a>
  <a href="#faq" class="mobile-link">FAQ</a>
  <a href="#contacto" class="mobile-link">Contacto</a>
  <a href="#cotizacion" class="mobile-link" style="color:var(--red)">→ Cotizar ahora</a>
</div>

<!-- ===== HERO ===== -->
<section id="hero">
  <div class="hero-video">
    <video autoplay loop muted playsinline>
      <source src="https://racksparaguay.com.py/wp-content/uploads/2023/09/Untitled-design-7-Compressed-with-FlexClip.mp4" type="video/mp4">
    </video>
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-slash"></div>

  <div class="hero-content">
    <div class="hero-left">
      <div class="hero-eyebrow">
        <div class="hero-eyebrow-line"></div>
        <span>Km 26 Ruta 2 · Itauguá · Paraguay</span>
      </div>

      <h1 class="hero-title">
        Soluciones de<br>
        <em>Almacenamiento</em>
        <span class="outline">Metálico</span>
      </h1>

      <p class="hero-sub">
        Diseñamos, fabricamos e instalamos sistemas de racks metálicos a medida para depósitos, almacenes, industrias y comercios en toda la región.
      </p>

      <div class="hero-btns">
        <a href="#cotizacion" class="btn btn-red">📋 Solicitar Cotización</a>
        <a href="#catalogo" class="btn btn-outline">Ver Catálogo</a>
      </div>

      <div class="hero-stats">
        <div>
          <div class="hero-stat-num">10+</div>
          <div class="hero-stat-label">Años de experiencia</div>
        </div>
